# Global orchestrator configuration for dev-kit root scripts.
# Copy to .orchestrator.env and customize as needed.

# --- Global orchestrator behavior ---
ORCH_FAIL_FAST=true
ORCH_AUTO_HEALTHCHECK=true
ORCH_LOG_TAIL=200
ORCH_DEFAULT_MODULES=all
ORCH_AUTO_INSTALL_PACKAGES=false
ORCH_ENABLE_CERTBOT_TIMER=true

# --- Module enablement ---
POSTGRES_ENABLED=true
KEYCLOAK_ENABLED=true
MINIO_ENABLED=true
OPENFGA_ENABLED=true

# --- Nginx exposure flags ---
# If false, the service remains local-only and no nginx vhost is managed.
POSTGRES_NGINX_ACME_ENABLED=false
KEYCLOAK_NGINX_ENABLED=false
MINIO_NGINX_ENABLED=false
OPENFGA_NGINX_ENABLED=false

# --- TLS flags ---
# TLS setup requires nginx enabled + valid domain(s).
POSTGRES_STREAM_TLS_ENABLED=false
KEYCLOAK_TLS_ENABLED=false
MINIO_TLS_ENABLED=false
OPENFGA_TLS_ENABLED=false

# --- Domains ---
# Leave empty to keep service local-only (no nginx/certbot for that service).
POSTGRES_DOMAIN=
KEYCLOAK_DOMAIN=
OPENFGA_DOMAIN=
MINIO_API_DOMAIN=
MINIO_CONSOLE_DOMAIN=
